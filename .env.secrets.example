# ──────────────────────────────────────────────────────────────
#  .env.secrets — Admin password hash only
#  Copy to .env.secrets and paste your bcrypt hash.
#  Generate with: npm run hash-password yourpassword
#
#  IMPORTANT: Do NOT escape the $ signs — paste the hash as-is.
#  NEVER commit this file to git.
# ──────────────────────────────────────────────────────────────

ADMIN_PASSWORD_HASH=$2a$12$replace_this_with_your_real_bcrypt_hash
