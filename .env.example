# ──────────────────────────────────────────────────────────────
#  Portfolio — Environment Variables Example
#  Copy this file to .env and fill in every value before running.
#  See README.md for full setup instructions.
# ──────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── MySQL ──────────────────────────────────────────────────────
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=portfolio
MYSQL_USER=portfolio_user
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_PASSWORD=change_me_app_password

# ── phpMyAdmin ─────────────────────────────────────────────────
PMA_PORT=8088

# ── Auth ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64
SESSION_SECRET=change_me_generate_with_openssl_rand_hex_64

# Admin username (plain text)
ADMIN_USERNAME=admin
# Admin password hash — generate with: npm run hash-password yourpassword
# Then put the result in .env.secrets, NOT here.
# ADMIN_PASSWORD_HASH is loaded from .env.secrets via Docker env_file

# ── Cloudflare Turnstile ───────────────────────────────────────
# Get keys from: https://dash.cloudflare.com → Turnstile
# For local dev, use the always-pass test keys below instead:
#   NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=change_me_turnstile_site_key
TURNSTILE_SECRET_KEY=change_me_turnstile_secret_key

# ── SMTP / Email ───────────────────────────────────────────────
SMTP_HOST=127.0.0.1
SMTP_PORT=25
SMTP_FROM=portfolio@localhost
CONTACT_TO_EMAIL=you@example.com
